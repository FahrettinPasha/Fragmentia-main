# =============================================================================
# SESSION / PER-FRAME GLOBALS — run_game_loop yerel değişkenlerinin
# modül-düzeyine taşınmış karşılıkları.
# event_handler.py ve render_pipeline.py bu değişkenlere _m.xxx üzerinden erişir.
# =============================================================================

# Her frame hesaplanır — while döngüsü başında güncellenir
time_ms   = 0        # pygame.time.get_ticks() bu frame
mouse_pos = (0, 0)   # ölçeklendirilmiş fare konumu
dt        = 0.016    # saniye cinsinden delta zaman
frame_mul = 1.0      # dt * 60 — frame-rate bağımsız hareket

# Ana döngü sentineli (eski yerel `running` değişkeninin karşılığı)
game_running = False

# Oyuncu / kamera oturumu
is_super_mode         = False
player_direction      = 1      # +1 sağ / -1 sol
manor_camera_offset_x = 0
manor_camera_offset_y = 0
